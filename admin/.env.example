# =============================================================================
# FastVisa Admin — Environment Template
# Copy: cp .env.example .env.local
# Production: set NEXT_PUBLIC_API_URL BEFORE `npm run build`
# =============================================================================

# --- API (REQUIRED prod build) ---
# URL backend Express — production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:5000

# --- Soketi / Pusher (optional — live chat) ---
# NEXT_PUBLIC_SOKETI_KEY phải = api SOKETI_APP_KEY
NEXT_PUBLIC_SOKETI_KEY=
NEXT_PUBLIC_SOKETI_HOST=127.0.0.1
NEXT_PUBLIC_SOKETI_PORT=6001
NEXT_PUBLIC_SOKETI_CLUSTER=mt1
NEXT_PUBLIC_SOKETI_FORCE_TLS=false

# --- Cloudinary (Upload Reels) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=fastvisa_unsigned

# =============================================================================
# Local dev ports: Admin :3001 | API :5000 | UI :3000
# Admin không cần REVALIDATE_SECRET — revalidate do API trigger sang UI
# =============================================================================
#
# --- Admin deploy (production) ---
# 1. Set env BEFORE build:
#      NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# 2. npm run build
# 3. npm run verify:build-env
# 4. npm run start              # :3001 — hoặc pm2 start ecosystem.config.cjs
# 5. Đảm bảo api ADMIN_URL + CORS trỏ đúng admin domain
# =============================================================================
