{
    "name": "fastvisa-api",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
        "dev:log": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts 2>&1 | tee api.log",
        "dev:all": "concurrently \"npm run dev\" \"npm run worker:dev\" \"npm run schedule:dev\"",
        "dev:log:all": "concurrently \"npm run dev:log\" \"npm run worker:dev\" \"npm run schedule:dev\"",
        "build": "tsc && tsc-alias",
        "start": "node -r tsconfig-paths/register -r module-alias/register dist/server.js",
        "start:all": "concurrently -n api,worker,schedule -c blue,magenta,green \"npm run start\" \"npm run worker\" \"npm run schedule\"",
        "verify:prod-boot": "node scripts/verify-prod-boot.mjs",
        "verify:health": "node scripts/verify-health.mjs",
        "verify:revalidate-e2e": "node scripts/verify-revalidate-e2e.mjs",
        "verify:admin-uat": "node scripts/verify-admin-uat.mjs",
        "verify:go-live": "node scripts/verify-go-live.mjs",
        "verify:go-live:preflight": "node scripts/verify-go-live.mjs preflight",
        "verify:go-live:postflight": "node scripts/verify-go-live.mjs postflight",
        "rollback:guide": "node scripts/verify-go-live.mjs rollback",
        "typecheck": "tsc --noEmit",
        "db:migrate:status": "prisma migrate status",
        "db:migrate:deploy": "prisma migrate deploy",
        "db:seed": "prisma db seed",
        "db:seed-admin": "tsx scripts/seed-admin.ts",
        "db:setup": "npm run db:migrate:deploy && npm run db:seed && npm run db:seed-admin",
        "worker:dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/worker.ts",
        "worker": "node -r tsconfig-paths/register -r module-alias/register dist/worker.js",
        "schedule:dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/schedule.ts",
        "schedule": "node -r tsconfig-paths/register -r module-alias/register dist/schedule.js",
        "test": "vitest run",
        "e2e:page-content": "node scripts/e2e-chat-page-content.mjs",
        "e2e:session-memory": "node scripts/e2e-chat-session-memory.mjs",
        "e2e:virtual-mouse": "node scripts/e2e-virtual-mouse.mjs",
        "e2e:apply-step1-sequencing": "node scripts/e2e-apply-step1-sequencing.mjs",
        "nlp:expand": "node scripts/expand-utterances.mjs",
        "nlp:expand:dry": "node scripts/expand-utterances.mjs --dry-run"
    },
    "_moduleAliases": {
        "@": "dist"
    },
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
        "@prisma/adapter-mariadb": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@sentry/node": "^8.55.0",
        "@vitalets/google-translate-api": "^9.2.1",
        "bcryptjs": "^2.4.3",
        "bing-translate-api": "^4.2.0",
        "cloudinary": "^2.10.0",
        "concurrently": "^9.2.1",
        "cors": "^2.8.5",
        "cron": "^4.4.0",
        "dotenv": "^16.4.5",
        "ejs": "^6.0.1",
        "express": "^4.21.0",
        "express-rate-limit": "^7.4.1",
        "helmet": "^8.0.0",
        "i18n-iso-countries": "^7.14.0",
        "jsonrepair": "^3.14.0",
        "jsonwebtoken": "^9.0.2",
        "module-alias": "^2.2.3",
        "morgan": "^1.10.0",
        "mrz": "^5.0.2",
        "multer": "^2.1.1",
        "node-nlp": "^5.0.0-alpha.5",
        "nodemailer": "^6.10.1",
        "pusher": "^5.3.3",
        "ts-node": "^10.9.2",
        "typescript": "^5.6.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/cron": "^2.0.1",
        "@types/ejs": "^3.1.5",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^2.1.0",
        "@types/node": "^22.7.0",
        "@types/nodemailer": "^6.4.23",
        "@types/supertest": "^7.2.0",
        "cheerio": "^1.2.0",
        "prisma": "^7.8.0",
        "pusher-js": "^8.5.0",
        "supertest": "^7.2.2",
        "ts-node-dev": "^2.0.0",
        "tsc-alias": "^1.8.10",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.19.0",
        "vitest": "^4.1.7"
    }
}
