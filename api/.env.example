# =============================================================================
# FastVisa API — Environment Template
# Copy: cp .env.example .env
# Production: set ALL required vars (see validate-production-env.ts)
# =============================================================================

# --- Server (REQUIRED prod) ---
PORT=5000
NODE_ENV=development

# --- Database (REQUIRED prod) ---
# MySQL 8: adapter tự thêm allowPublicKeyRetrieval nếu thiếu (xem src/lib/mariadb-connection.ts)
DATABASE_URL="mysql://user:password@localhost:3306/fastvisa"

# --- Auth (REQUIRED prod) ---
# JWT_SECRET: ≥32 ký tự random — openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_IN=7d
# Email duy nhất được phép đăng nhập admin panel
ALLOWED_ADMIN_EMAIL=vietnmf8@fullstack.edu.vn

# --- Admin seed (chạy npm run db:seed-admin — chỉ lần đầu / đổi mật khẩu) ---
# Production: đặt ADMIN_SEED_PASSWORD mạnh, chạy seed-admin một lần, rồi xóa khỏi env runtime
ADMIN_SEED_PASSWORD=
ADMIN_SEED_NAME=FastVisa Admin
ADMIN_SEED_PHONE=0900000000

# --- CORS & URLs (REQUIRED prod) ---
# Phải khớp origin thực tế của UI và Admin (scheme + host + port)
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
# Base URL UI — API gọi POST {UI_BASE_URL}/api/revalidate sau admin CRUD
UI_BASE_URL=http://localhost:3000

# --- ISR Revalidation (REQUIRED prod) ---
# Phải TRÙNG REVALIDATE_SECRET trong ui/.env — ≥16 ký tự random
REVALIDATE_SECRET=

# --- Sentry (optional) ---
SENTRY_DSN=

# --- Cloudinary (recommended prod — admin upload ảnh) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# --- PayPal Orders v2 (optional — sandbox/live từ https://developer.paypal.com) ---
PAYPAL_MODE=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_VND_PER_USD=

# --- Gmail / Nodemailer (recommended prod) ---
# App Password: https://nodemailer.com/guides/using-gmail
MAIL_FROM_NAME=
MAIL_FROM_ADDRESS=
MAIL_APP_PASSWORD=
# Để trống = gửi bản admin notify vào chính MAIL_FROM_ADDRESS
ADMIN_NOTIFY_EMAIL=

# --- Soketi / Pusher-compatible (recommended prod — live chat) ---
# NEXT_PUBLIC_SOKETI_KEY (ui/admin) phải = SOKETI_APP_KEY
SOKETI_APP_ID=
SOKETI_APP_KEY=
SOKETI_APP_SECRET=
SOKETI_APP_CLUSTER=mt1
SOKETI_HOST=127.0.0.1
SOKETI_PORT=6001

# --- Gemini (optional — AI chatbot) ---
GEMINI_API_KEY=

# =============================================================================
# Production matrix (quick reference)
# -----------------------------------------------------------------------------
# | Variable           | Must match                          |
# |--------------------|-------------------------------------|
# | REVALIDATE_SECRET  | ui REVALIDATE_SECRET                |
# | SOKETI_APP_KEY     | ui/admin NEXT_PUBLIC_SOKETI_KEY     |
# | FRONTEND_URL       | UI public URL (PayPal return URL)   |
# | ADMIN_URL          | Admin public URL                    |
# | UI_BASE_URL        | Same as FRONTEND_URL in most setups |
# | NEXT_PUBLIC_API_URL| Set on ui/admin at BUILD time       |
# =============================================================================
#
# --- Database deploy (production) ---
# 1. npx prisma migrate status
# 2. npm run db:migrate:deploy    # KHÔNG dùng migrate dev trên prod
# 3. npm run db:seed              # Idempotent — upsert lookup/content
# 4. npm run db:seed-admin        # Tạo admin (ALLOWED_ADMIN_EMAIL)
# Hoặc gộp: npm run db:setup
# =============================================================================
#
# --- API deploy (production — 3 processes) ---
# Build:     npm run build
# Option A — PM2 (recommended):
#   pm2 start ecosystem.config.cjs
#   pm2 status && npm run verify:health
# Option B — foreground (debug):
#   npm run start:all
# Processes:
#   fastvisa-api       → dist/server.js   (HTTP :PORT)
#   fastvisa-worker    → dist/worker.js   (abandoned cart, 10 phút)
#   fastvisa-schedule  → dist/schedule.js (Cloudinary cleanup, 02:00 ngày 1)
# Health: GET {API_URL}/api/v1/health → { "data": { "status": "ok" } }
#
# --- Revalidate E2E (Phase 6) ---
# Yêu cầu: UI + API dev đang chạy; REVALIDATE_SECRET trùng ui/.env.local
#   npm run verify:revalidate-e2e
# Flow: Admin PUT FAQ → revalidateCache("faqs") → POST {UI_BASE_URL}/api/revalidate
#
# --- Go-live (Phase 7) ---
# Preflight (CI / trước deploy):
#   npm run verify:go-live:preflight
# Postflight (sau deploy, stack đang chạy):
#   npm run verify:go-live:postflight
# Full gate + rollback guide:
#   npm run verify:go-live
#   npm run rollback:guide
# =============================================================================
