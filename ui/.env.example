# =============================================================================
# FastVisa UI — Environment Template
# Copy: cp .env.example .env.local
# Production: set vars BEFORE `npm run build` (NEXT_PUBLIC_* baked at build)
# =============================================================================

# --- API (REQUIRED prod build) ---
# URL backend Express — production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:5000

# --- Site metadata (recommended prod) ---
# Canonical URL của UI — dùng trong layout/metadata (khác NEXT_PUBLIC_API_URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- ISR Revalidation (REQUIRED prod) ---
# Phải TRÙNG REVALIDATE_SECRET trong api/.env
REVALIDATE_SECRET=

# --- Soketi / Pusher-JS (optional — live chat) ---
# NEXT_PUBLIC_SOKETI_KEY phải = api SOKETI_APP_KEY
NEXT_PUBLIC_SOKETI_HOST=127.0.0.1
NEXT_PUBLIC_SOKETI_PORT=6001
NEXT_PUBLIC_SOKETI_KEY=
NEXT_PUBLIC_SOKETI_CLUSTER=mt1
NEXT_PUBLIC_SOKETI_FORCE_TLS=false

# =============================================================================
# Local dev ports: UI :3000 | API :5000 | Admin :3001 | Soketi :6001
# =============================================================================
#
# --- UI deploy (production) ---
# 1. Set env (Vercel dashboard hoặc .env.production.local):
#      NEXT_PUBLIC_API_URL=https://api.yourdomain.com
#      NEXT_PUBLIC_SITE_URL=https://yourdomain.com
#      REVALIDATE_SECRET=<same as api>
# 2. npm run build
# 3. npm run verify:build-env   # confirm API URL baked
# 4. npm run start              # hoặc pm2 start ecosystem.config.cjs
# 5. npm run verify:prod-boot   # smoke :3020 (optional)
#
# --- Revalidate (server-only, KHÔNG NEXT_PUBLIC) ---
# REVALIDATE_SECRET phải trùng api/.env — dùng bởi POST /api/revalidate
# =============================================================================
